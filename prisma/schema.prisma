// Plum Tabletop — Prisma schema
// Postgres 16 + pgvector + pg_trgm + citext

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "linux-musl", "debian-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector, citext, pg_trgm]
}

// ─── Users & Auth ─────────────────────────────────────────────────
// `User` is provisioned on first Authelia-authenticated request.
// `username` and `email` come from Authelia headers.
// `encOpenAIKey` stores per-user encrypted OpenAI-compatible API fallback key.
model User {
  id            String   @id @default(cuid())
  username      String   @unique @db.Citext
  email         String?  @unique @db.Citext
  displayName   String?
  isDM          Boolean  @default(false)
  encOpenAIKey  Bytes?
  openAIBaseUrl String?
  openAIModelDm String?
  codexModelDm         String?
  codexReasoningEffort String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastSeenAt    DateTime @default(now())

  campaignsHosted Campaign[]      @relation("CampaignHost")
  characters      Character[]
  sessionMembers  SessionMember[]
  eventLog        EventLog[]
  invitesIssued   Invite[]
}

// ─── Campaign ─────────────────────────────────────────────────────
enum CampaignStatus {
  draft // worldbuilding wizard
  generating // assets being produced
  ready // playable
  playing // session live
  archived
}

enum LoreSourceKind {
  upload
  web_research
}

enum LoreSourceStatus {
  ready
  failed
}

model Campaign {
  id                   String         @id @default(cuid())
  hostId               String
  host                 User           @relation("CampaignHost", fields: [hostId], references: [id])
  title                String
  theme                String
  tone                 String?
  systemPromptOverride String?
  status               CampaignStatus @default(draft)
  styleSuffix          String? // master style suffix for asset prompts
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  world      CampaignWorld?
  characters Character[]
  npcs       NPC[]
  locations  Location[]
  items      Item[]
  encounters Encounter[]
  scenes     Scene[]
  sessions   GameSession[]
  assets     Asset[]
  invites    Invite[]
  voiceAssignments VoiceAssignment[]
  loreSources CampaignLoreSource[]

  @@index([hostId])
  @@index([status])
}

model CampaignWorld {
  campaignId String   @id
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  plot       Json // 3-act plot structure
  factions   Json     @default("[]")
  worldFacts Json     @default("[]")
  threads    Json     @default("[]") // active plot threads
  loreBible  Json     @default("{}")
  gameState  Json     @default("{}") // versioned quests, decisions, reputation
  updatedAt  DateTime @updatedAt
}

model CampaignLoreSource {
  id          String           @id @default(cuid())
  campaignId  String
  campaign    Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  kind        LoreSourceKind
  status      LoreSourceStatus @default(ready)
  title       String
  sourceUrl   String?
  contentHash String
  rawText     String?          @db.Text
  summary     String           @db.Text
  facts       Json             @default("[]")
  citations   Json             @default("[]")
  errorMsg    String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([campaignId, kind])
  @@index([contentHash])
}

// ─── Character / NPC ──────────────────────────────────────────────
model Character {
  id              String   @id @default(cuid())
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id])
  name            String
  sheet           Json // D&D 5e character sheet JSON
  runtime         Json     @default("{}") // versioned resources, inventory, equipment, death saves
  tokenAssetId    String?
  tokenAsset      Asset?   @relation("CharacterToken", fields: [tokenAssetId], references: [id])
  portraitAssetId String?
  portraitAsset   Asset?   @relation("CharacterPortrait", fields: [portraitAssetId], references: [id])
  pairingInvites  Invite[] @relation("CharacterPairingInvites")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([campaignId])
  @@index([campaignId, createdAt])
  @@index([ownerId])
}

model NPC {
  id              String   @id @default(cuid())
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name            String
  role            String? // shopkeeper, antagonist, ally, etc.
  description     String?
  sheet           Json // monster/NPC stat block
  portraitAssetId String?
  portraitAsset   Asset?   @relation("NPCPortrait", fields: [portraitAssetId], references: [id])
  tokenAssetId    String?
  tokenAsset      Asset?   @relation("NPCToken", fields: [tokenAssetId], references: [id])
  visibility      String   @default("hidden") // hidden|revealed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([campaignId])
  @@index([campaignId, visibility, updatedAt])
}

// ─── World Geography ──────────────────────────────────────────────
model Location {
  id                 String   @id @default(cuid())
  campaignId         String
  campaign           Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  ambience           String?
  backgroundAssetId  String?
  backgroundAsset    Asset?   @relation("LocationBackground", fields: [backgroundAssetId], references: [id])
  tacticalMapAssetId String?
  tacticalMapAsset   Asset?   @relation("LocationTacticalMap", fields: [tacticalMapAssetId], references: [id])
  gridConfig         Json? // {type: 'square'|'hex', cellSize: 50, ...}
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([campaignId])
  @@index([campaignId, name])
}

model Item {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name        String
  description String?
  data        Json // weight, value, magic properties, etc.
  iconAssetId String?
  iconAsset   Asset?   @relation("ItemIcon", fields: [iconAssetId], references: [id])
  createdAt   DateTime @default(now())

  @@index([campaignId])
}

// ─── Assets (images, maps, tokens) ────────────────────────────────
enum AssetKind {
  npc_portrait
  npc_token
  character_portrait
  character_token
  location_background
  location_tactical_map
  item_icon
  scene_keyframe
  custom
}

enum AssetStatus {
  pending
  queued
  generating
  ready
  failed
}

model Asset {
  id             String      @id @default(cuid())
  campaignId     String?
  campaign       Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  kind           AssetKind
  status         AssetStatus @default(pending)
  prompt         String      @db.Text
  negativePrompt String?     @db.Text
  backend        String? // codex-cli|openai|pregenerated|library
  s3Key          String?
  url            String? // public CDN URL
  width          Int?
  height         Int?
  errorMsg       String?
  jobId          String?
  meta           Json?
  createdAt      DateTime    @default(now())
  generatedAt    DateTime?

  npcsPortrait       NPC[]       @relation("NPCPortrait")
  npcsToken          NPC[]       @relation("NPCToken")
  charactersToken    Character[] @relation("CharacterToken")
  charactersPortrait Character[] @relation("CharacterPortrait")
  locationsBg        Location[]  @relation("LocationBackground")
  locationsMap       Location[]  @relation("LocationTacticalMap")
  itemsIcon          Item[]      @relation("ItemIcon")

  @@index([campaignId, kind])
  @@index([status])
}

// ─── Scenes (narrative units) ─────────────────────────────────────
enum SceneType {
  intro
  exploration
  social
  combat
  rest
  cutscene
  outro
}

model Scene {
  id         String    @id @default(cuid())
  campaignId String
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  order      Int
  type       SceneType
  title      String
  payload    Json // {locationId, presentNpcIds, summary, hooks, ...}
  visited    Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([campaignId, order])
  @@index([campaignId])
}

// ─── Encounters ───────────────────────────────────────────────────
enum EncounterStatus {
  prepared
  active
  resolved
  fled
}

model Encounter {
  id         String          @id @default(cuid())
  campaignId String
  campaign   Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name       String
  monsters   Json // [{srdRef, count, hp, ...}]
  initiative Json            @default("[]") // ordered turn list
  status     EncounterStatus @default(prepared)
  locationId String?
  round      Int             @default(0)
  activeTurn Int             @default(0)
  runtime    Json            @default("{}") // plans, reactions, surfaces, objects, visibility, objectives
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([campaignId])
  @@index([campaignId, status, updatedAt])
}

enum VoiceTargetType {
  narrator
  npc
  character
}

enum TtsAudioStatus {
  ready
  failed
}

model VoiceAssignment {
  id           String         @id @default(cuid())
  campaignId   String
  campaign     Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  targetType   VoiceTargetType
  targetId     String
  vocariumUser String
  voiceId      String
  voiceName    String
  voiceSource  String         @default("clone")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([campaignId, targetType, targetId])
  @@index([campaignId, targetType])
  @@index([voiceId])
}

// ─── Live Game Sessions ───────────────────────────────────────────
model GameSession {
  id         String          @id @default(cuid())
  campaignId String
  campaign   Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  startedAt  DateTime        @default(now())
  endedAt    DateTime?
  summary    String?         @db.Text
  runtime    Json            @default("{}") // votes, rest proposals, active cooperative decisions
  members    SessionMember[]
  events     EventLog[]
  ttsAudioCache TtsAudioCache[]
  pairingInvites Invite[]         @relation("SessionPairingInvites")

  @@index([campaignId])
}

model TtsAudioCache {
  id         String        @id @default(cuid())
  sessionId  String
  session    GameSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventId    String
  voiceId    String
  textHash   String
  audio      Bytes?
  mimeType   String?
  byteLength Int           @default(0)
  status     TtsAudioStatus
  error      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([sessionId, eventId, voiceId, textHash])
  @@index([sessionId, eventId])
  @@index([status, updatedAt])
}

model SessionMember {
  id          String      @id @default(cuid())
  sessionId   String
  session     GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  inviteId    String? // for non-Authelia players
  displayName String
  characterId String?
  joinedAt    DateTime    @default(now())
  leftAt      DateTime?

  @@index([sessionId])
  @@index([sessionId, userId])
  @@index([sessionId, inviteId])
  @@index([sessionId, characterId])
  @@index([userId])
}

// ─── Event Log (append-only, replayable) ──────────────────────────
model EventLog {
  id        String      @id @default(cuid())
  sessionId String
  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?       @relation(fields: [actorId], references: [id])
  type      String // narrate|roll|move|attack|skill_check|...
  payload   Json
  scope     String      @default("all") // all|dm
  ts        DateTime    @default(now())

  @@index([sessionId, ts])
  @@index([sessionId, type, ts, id])
  @@index([sessionId, scope, ts])
  @@index([type])
}

// ─── Invites (for non-Authelia players) ───────────────────────────
model Invite {
  id          String    @id @default(cuid())
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  issuedById  String
  issuedBy    User      @relation(fields: [issuedById], references: [id])
  sessionId   String?
  session     GameSession? @relation("SessionPairingInvites", fields: [sessionId], references: [id], onDelete: Cascade)
  characterId String?
  character   Character? @relation("CharacterPairingInvites", fields: [characterId], references: [id], onDelete: Cascade)
  code        String    @unique // HMAC-signed token; URL-safe
  displayName String? // pre-filled name for the guest
  expiresAt   DateTime
  usedAt      DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([campaignId])
  @@index([sessionId])
  @@index([sessionId, characterId])
}

// ─── SRD (D&D 5.1 SRD content) ────────────────────────────────────
enum SRDType {
  spell
  monster
  rule
  item
  class
  race
  background
  feat
  condition
  feature
}

model SRDChunk {
  id        String                        @id @default(cuid())
  type      SRDType
  name      String
  slug      String                        @unique
  source    String // path within srd repo
  content   String                        @db.Text
  data      Json? // structured fields for monsters/spells
  embedding Unsupported("halfvec(3072)")?
  createdAt DateTime                      @default(now())
  updatedAt DateTime                      @updatedAt

  @@index([type])
  @@index([name])
}
