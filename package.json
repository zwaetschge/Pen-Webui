{
  "name": "dnd-webui",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted D&D 5e VTT with Codex (GPT-5) as autonomous Dungeon Master.",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "srd:sync": "tsx scripts/sync-srd.ts",
    "assets:pregen": "tsx scripts/pregen-assets.ts",
    "worker": "tsx workers/asset-worker.ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.687.0",
    "@aws-sdk/s3-request-presigner": "^3.687.0",
    "@openai/codex": "^0.134.0",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.59.0",
    "@types/libsodium-wrappers-sumo": "^0.7.8",
    "@types/three": "^0.185.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "bullmq": "^5.21.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.0",
    "ioredis": "^5.4.1",
    "libsodium-wrappers-sumo": "^0.8.4",
    "next": "^15.5.18",
    "openai": "^4.73.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "pixi.js": "^8.5.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.5.4",
    "three": "^0.185.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.48.2",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
